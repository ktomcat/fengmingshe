<!-- 首页页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="精选" 
      background="#ffffff" 
      color="#f44343" 
      back="{{false}}"
      home-button="{{false}}"
      left-logo="{{true}}"
      show-title="{{false}}"
    ></navigation-bar>
  </view>


  <!-- 页面内容区域 -->
  <view class="page-content">
  <!-- 特色话题卡片 -->
  

  <!-- 热门讨论列表 -->
  <view class="discussions-section">
    <!-- 动态生成讨论帖子 -->
    <view class="discussion-post" wx:for="{{discussions}}" wx:key="id">
      <view class="post-content-area" bindtap="goToTopicDetail" data-topic-id="{{item.id}}">
        <view class="post-header">
          <view class="user-info">
            <image class="avatar" src="{{item.author.avatar}}" />
            <view class="user-details">
              <text class="username">{{item.author.nickname}}</text>
              <text class="post-info">{{item.createTime}} </text>
            </view>
          </view>
          <view class="more-btn" catchtap="showBottomSheet" data-topic="{{item}}">
            <text class="icon">⋯</text>
          </view>
        </view>
        
        <text class="post-title">{{item.title}}</text>
        
        <!-- 显示第一个文本内容 -->
        <text class="post-content" wx:if="{{item.displayContent}}">
          {{item.displayContent}}
        </text>
        
        <!-- 图片展示 - 横向滚动布局 -->
        <view class="post-images-container" wx:if="{{item.content && item.content.length > 0}}">
          <scroll-view class="post-images-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
            <view class="post-images-list">
              <image class="post-image" wx:for="{{item.content}}" wx:for-item="contentItem" wx:key="index" wx:if="{{contentItem.type === 'image'}}" src="{{contentItem.content}}" mode="aspectFill" />
            </view>
          </scroll-view>
          <view class="scroll-indicator" wx:if="{{getImageCount(item.content) > 3}}">
            <text class="indicator-text">滑动查看更多</text>
          </view>
        </view>
      </view>
      
      <!-- 操作按钮区域（独立事件处理，阻止冒泡） -->
      <view class="post-actions">
        <view class="action-buttons">
          <view class="action-btn style-unactive" bindtap="onLikePost" data-topic-id="{{item.id}}">
            <text class="icon">❤️</text>
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn" bindtap="onCommentPost" data-topic-id="{{item.id}}">
            <text class="icon">💬</text>
            <text class="action-count">{{item.commentCount}}</text>
          </view>
          <view class="action-btn" bindtap="onSharePostInList" data-topic="{{item}}">
            <text class="icon">↗️</text>
            <text class="action-count">{{item.share}}分享</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{1}}" 
    bind:change="onTabChange"
  />
  </view>

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onSharePost">
        <text class="sheet-icon">📤</text>
        <text class="sheet-text">分享帖子</text>
      </view>
      <view class="sheet-item" bindtap="onCopyLink">
        <text class="sheet-icon">🔗</text>
        <text class="sheet-text">复制链接</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>