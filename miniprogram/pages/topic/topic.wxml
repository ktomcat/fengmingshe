<!-- 话题详情页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="话题详情" 
      background="#ffffff" 
      color="#000000" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 话题头部信息 -->
    <view class="topic-header" wx:if="{{topic}}">
      <!-- 作者信息 -->
      <view class="author-info">
        <image class="avatar" src="{{topic.author.avatar}}" />
        <view class="author-details">
          <text class="author-name">{{topic.author.nickname}}</text>
          <text class="post-time">{{topic.createTime}}</text>
        </view>
        <view class="more-btn" bindtap="showBottomSheet">
          <text class="more-icon">⋯</text>
        </view>
      </view>
      
      <!-- 话题内容 -->
      <text class="topic-title">{{topic.title}}</text>
      
      <!-- 图文混排内容展示 -->
      <view class="mixed-content" wx:if="{{topic.content && topic.content.length > 0}}">
        <view class="content-item" wx:for="{{topic.content}}" wx:for-item="contentItem" wx:key="index">
          <!-- 文本内容 -->
          <text class="content-text" wx:if="{{contentItem.type === 'text'}}">{{contentItem.content}}</text>
          
          <!-- 图片内容 -->
          <view class="content-image-wrapper" wx:if="{{contentItem.type === 'image'}}">
            <image class="content-image" src="{{contentItem.content}}" mode="aspectFill" />
          </view>
          
          <!-- 投票内容 -->
          <view class="vote-section" wx:if="{{contentItem.type === 'vote'}}">
            <view class="vote-container">
              <view class="vote-header">
                <text class="vote-title">{{contentItem.content.title}}</text>
                <text class="vote-count">{{contentItem.content.totalVotes}} 人参与</text>
              </view>
              
              <view class="vote-content">
                <view class="vote-stats">
                  <view class="stats-left">
                    <text class="stats-label">支持 (正方)</text>
                    <text class="stats-value">{{contentItem.content.positive.count}}</text>
                  </view>
                  <view class="stats-right">
                    <text class="stats-label">反对 (反方)</text>
                    <text class="stats-value">{{contentItem.content.negative.count}}</text>
                  </view>
                </view>
                
                <view class="vote-progress-bar">
                  <view class="progress-track">
                    <view class="progress-fill positive" style="width: {{contentItem.content.positivePercent || 0}}%"></view>
                    <view class="progress-fill negative" style="width: {{contentItem.content.negativePercent || 0}}%"></view>
                    <view class="progress-divider" style="left: {{contentItem.content.positivePercent || 0}}%"></view>
                  </view>
                </view>
                
                <view class="vote-actions" wx:if="{{!contentItem.content.userVoted}}">
                  <button class="vote-btn positive" bindtap="onVotePositive" data-content-index="{{index}}">
                    <image class="btn-icon" src="/static/icons/like.png" />
                    <text class="btn-text">支持观点</text>
                  </button>
                  <button class="vote-btn negative" bindtap="onVoteNegative" data-content-index="{{index}}">
                    <image class="btn-icon" src="/static/icons/like.png" />
                    <text class="btn-text">反对观点</text>
                  </button>
                </view>
                
                <view class="vote-result" wx:if="{{contentItem.content.userVoted}}">
                  <text class="result-text">
                    你选择了 {{contentItem.content.userChoice === 'positive' ? '正方' : '反方'}}
                  </text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 统计信息 -->
      <view class="topic-stats">
        <view class="stat-item {{topic.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikeTopic">
          <image class="icon" src="/static/icons/heart.png" />
          <text class="stat-count">{{topic.likeCount}}</text>
        </view>
        <view class="stat-item  style-unactive" bindtap="onShareTopic">
          <image class="icon" src="/static/icons/share.png" />
          <text class="stat-count">分享</text>
        </view>
      </view>
    </view>



    <!-- 评论导航 -->
    <view class="comment-nav">
      <view class="nav-text">全部评论</view>
      <view class="sort-options">
        <text class="sort-option {{sortType === 'time' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="time">最新</text>
        <text class="sort-divider">|</text>
        <text class="sort-option {{sortType === 'hot' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="hot">最热</text>
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="comment-section">
      <view class="comment-card" wx:for="{{comments}}" wx:key="id">
        <view class="comment-header">
          <view class="user-info">
            <image class="avatar" src="{{item.author.avatar}}" />
            <view class="user-details">
              <view class="username-row">
                <text class="username">{{item.author.nickname}}</text>
              </view>
              <text class="comment-info">{{item.createTime}}</text>
            </view>
          </view>
          <view class="more-btn" bindtap="showBottomSheet">
            <text class="more-icon">⋯</text>
          </view>
        </view>
        
        <text class="comment-content">{{item.content}}</text>
        
        <view class="comment-actions">
          <view class="action-btn {{item.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikeComment" data-comment="{{item}}" data-index="{{index}}">
            <image class="icon" src="/static/icons/heart.png" />
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn style-unactive" bindtap="onReplyComment" data-comment="{{item}}">
            <image class="icon" src="/static/icons/msg.png" />
            <text class="action-count">{{item.replyCount}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部输入框 -->
    <view class="input-section">
      <view class="input-container">
        <input class="comment-input" placeholder="写下你的看法..." bindinput="onCommentInput" />
        <button class="send-btn" bindtap="onSendComment">
          <text class="send-icon">➤</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{currentTab}}" 
    bind:change="onTabChange"
  />

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onSharePost">
        <text class="sheet-icon">📤</text>
        <text class="sheet-text">分享帖子</text>
      </view>
      <view class="sheet-item" bindtap="onCopyLink">
        <text class="sheet-icon">🔗</text>
        <text class="sheet-text">复制链接</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>