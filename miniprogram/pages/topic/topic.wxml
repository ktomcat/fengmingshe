<!-- 话题详情页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="话题详情" 
      background="#ffffff" 
      color="#000000" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 话题头部信息 -->
    <view class="topic-header" wx:if="{{topic}}">
      <!-- 作者信息 -->
      <view class="author-info">
        <image class="avatar" src="{{topic.author.avatar}}" />
        <view class="author-details">
          <text class="author-name">{{topic.author.nickname}}</text>
          <text class="post-time">{{topic.createTime}}</text>
        </view>
        <view class="more-btn" bindtap="showBottomSheet">
          <text class="more-icon">⋯</text>
        </view>
      </view>
      
      <!-- 话题内容 -->
      <text class="topic-title">{{topic.title}}</text>
      <text class="topic-content">{{topic.content}}</text>
      
      <!-- 图片展示 -->
      <view class="topic-images" wx:if="{{topic.images && topic.images.length > 0}}">
        <image class="topic-image" wx:for="{{topic.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
      </view>
      
      <!-- 标签展示 -->
      <view class="topic-tags" wx:if="{{topic.tags && topic.tags.length > 0}}">
        <text class="tag" wx:for="{{topic.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      
      <!-- 统计信息 -->
      <view class="topic-stats">
        <view class="stat-item">
          <text class="stat-icon">❤️</text>
          <text class="stat-count">{{topic.likeCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">💬</text>
          <text class="stat-count">{{topic.commentCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">↗️</text>
          <text class="stat-count">分享</text>
        </view>
      </view>
    </view>

    <!-- 评论导航 -->
    <view class="comment-nav">
      <view class="nav-text">全部评论</view>
      <view class="sort-options">
        <text class="sort-option {{sortType === 'time' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="time">最新</text>
        <text class="sort-divider">|</text>
        <text class="sort-option {{sortType === 'hot' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="hot">最热</text>
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="comment-section">
      <view class="comment-card" wx:for="{{comments}}" wx:key="id">
        <view class="comment-header">
          <view class="user-info">
            <image class="avatar" src="{{item.author.avatar}}" />
            <view class="user-details">
              <view class="username-row">
                <text class="username">{{item.author.nickname}}</text>
                <text class="featured-badge" wx:if="{{item.isFeatured}}">精选</text>
              </view>
              <text class="comment-info">{{item.createTime}}</text>
            </view>
          </view>
          <view class="more-btn" bindtap="showBottomSheet">
            <text class="more-icon">⋯</text>
          </view>
        </view>
        
        <text class="comment-content">{{item.content}}</text>
        
        <view class="comment-actions">
          <view class="action-btn" bindtap="onLikeComment" data-comment="{{item}}">
            <text class="action-icon">👍</text>
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn">
            <text class="action-icon">💬</text>
            <text class="action-count">{{item.replyCount}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部输入框 -->
    <view class="input-section">
      <view class="input-container">
        <input class="comment-input" placeholder="写下你的看法..." bindinput="onCommentInput" />
        <button class="send-btn" bindtap="onSendComment">
          <text class="send-icon">➤</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{currentTab}}" 
    bind:change="onTabChange"
  />

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onSharePost">
        <text class="sheet-icon">📤</text>
        <text class="sheet-text">分享帖子</text>
      </view>
      <view class="sheet-item" bindtap="onCopyLink">
        <text class="sheet-icon">🔗</text>
        <text class="sheet-text">复制链接</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>