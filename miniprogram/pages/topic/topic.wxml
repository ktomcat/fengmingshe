<!-- 话题详情页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar" id="fixed-navbar">
    <navigation-bar 
      title="话题详情" 
      background="#ffffff" 
      color="#D7423D" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 占位元素，用于获取导航栏高度 -->
  <view class="navbar-placeholder" hidden="{{true}}"></view>

  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 话题头部信息 -->
    <view class="topic-header" wx:if="{{topic}}" id="topic-header">
      <!-- 作者信息 -->
      <view class="author-info">
        <view class="author-info-left" bindtap="goToUserProfile" data-user-id="{{topic.authorId}}">
          <image class="avatar" src="{{topic.author.avatar}}" />
          <view class="author-details">
            <text class="author-name">{{topic.author.nickname}}</text>
            <text class="post-time">{{topic.createTime}}</text>
          </view>
        </view>
        <view class="more-btn" bindtap="showBottomSheet">
          <text class="more-icon">⋯</text>
        </view>
      </view>
      
      <!-- 话题内容 -->
      <text class="topic-title">{{topic.title}}</text>
      
      <!-- 图文混排内容展示 -->
      <view class="mixed-content" wx:if="{{topic.content && topic.content.length > 0}}">
        <view class="content-item" wx:for="{{topic.content}}" wx:for-item="contentItem" wx:key="index">
          <!-- 文本内容 -->
          <text class="content-text" wx:if="{{contentItem.type === 'text'}}">{{contentItem.content}}</text>
          
          <!-- 图片内容 -->
          <view class="content-image-wrapper" wx:if="{{contentItem.type === 'image'}}">
            <image class="content-image" src="{{contentItem.content}}" mode="aspectFill" />
          </view>
          
          <!-- 投票内容 -->
          <view class="vote-section" wx:if="{{contentItem.type === 'vote'}}">
            <view class="vote-container">
              <view class="vote-header">
                <text class="vote-title">{{contentItem.content.title}}</text>
                <text class="vote-count">{{contentItem.content.totalVotes}} 人参与</text>
              </view>
              
              <view class="vote-content">
                <view class="vote-stats">
                  <view class="stats-left">
                    <text class="stats-label">支持 (正方)</text>
                    <text class="stats-value">{{contentItem.content.positive.count}}</text>
                  </view>
                  <view class="stats-right">
                    <text class="stats-label">反对 (反方)</text>
                    <text class="stats-value">{{contentItem.content.negative.count}}</text>
                  </view>
                </view>
                
                <view class="vote-progress-bar">
                  <view class="progress-track">
                    <view class="progress-fill positive" style="width: {{contentItem.content.positivePercent || 0}}%"></view>
                    <view class="progress-fill negative" style="width: {{contentItem.content.negativePercent || 0}}%"></view>
                    <view class="progress-divider" style="left: {{contentItem.content.positivePercent || 0}}%"></view>
                  </view>
                </view>
                
                <view class="vote-actions" wx:if="{{!topic.voteChoice}}">
                  <button class="vote-btn positive" bindtap="onVotePositive" data-content-index="{{index}}">
                    <image class="btn-icon" src="/static/icons/like.png" />
                    <text class="btn-text">支持观点</text>
                  </button>
                  <button class="vote-btn negative" bindtap="onVoteNegative" data-content-index="{{index}}">
                    <image class="btn-icon" src="/static/icons/like.png" />
                    <text class="btn-text">反对观点</text>
                  </button>
                </view>
                
                <view class="vote-result" wx:if="{{topic.voteChoice}}">
                  <text class="result-text">
                    你选择了 {{topic.voteChoice === 'positive' ? '正方' : '反方'}}
                  </text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 统计信息 -->
      <view class="topic-stats">
        <view class="stat-item {{topic.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikeTopic">
          <image class="icon" src="/static/icons/heart.png" />
          <text class="stat-count">{{topic.likeCount}}</text>
        </view>
        <view class="stat-item  style-unactive" bindtap="onShareTopic">
          <image class="icon" src="/static/icons/share.png" />
          <text class="stat-count">分享</text>
        </view>
      </view>
    </view>

    <!-- 评论导航占位元素（用于吸顶时占位） -->
    <view class="comment-nav-placeholder" wx:if="{{isCommentNavSticky}}" style="height: {{commentNavHeight}}px;"></view>

    <!-- 评论导航 -->
    <view class="comment-nav {{isCommentNavSticky ? 'sticky' : ''}}" id="comment-nav" style="{{isCommentNavSticky ? 'top: ' + navbarHeight + 'px;' : ''}}">
      <view class="nav-text">全部评论</view>
      <view class="sort-options">
        <text class="sort-option {{sortType === 'time' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="time">最新</text>
        <text class="sort-divider">|</text>
        <text class="sort-option {{sortType === 'hot' ? 'active' : ''}}" 
              bindtap="switchSortType" 
              data-type="hot">最热</text>
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="comment-section">
      <view class="comment-card" wx:for="{{comments}}" wx:key="id">
        <view class="comment-header">
          <view class="user-info" bindtap="goToUserProfile" data-user-id="{{item.authorId}}">
            <image class="avatar" src="{{item.author.avatar}}" />
            <view class="user-details">
              <view class="username-row">
                <text class="username">{{item.author.nickname}}</text>
              </view>
              <text class="comment-info">{{item.createTime}}</text>
            </view>
          </view>
          <view class="more-btn" bindtap="showBottomSheet">
            <text class="more-icon">⋯</text>
          </view>
        </view>
        
        <!-- 评论内容 - 点击可回复 -->
        <text class="comment-content" bindtap="showReplyInput" data-comment="{{item}}" data-index="{{index}}">{{item.content}}</text>
        
        <view class="comment-actions">
          <view class="action-btn {{item.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikeComment" data-comment="{{item}}" data-index="{{index}}">
            <image class="icon" src="/static/icons/heart.png" />
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn style-unactive" bindtap="showReplyInput" data-comment="{{item}}" data-index="{{index}}">
            <image class="icon" src="/static/icons/msg.png" />
            <text class="action-count">{{item.replyCount}}</text>
          </view>
          <view class="action-btn style-unactive" bindtap="showReplyInput" data-comment="{{item}}" data-index="{{index}}">
            <text class="action-text">回复</text>
          </view>
        </view>
        
        <!-- 回复列表 -->
        <view class="replies-section" wx:if="{{item.replies && item.replies.length > 0}}">
          <!-- 按钮1：展开X条评论 ↓ (在子评论列表上方，折叠时显示，展开时消失) -->
          <view class="replies-toggle-top" wx:if="{{!expandedMap[item.id]}}" bindtap="toggleReplies" data-comment-id="{{item.id}}">
            <text class="toggle-text">展开{{item.replyCount}}条评论 ↓</text>
          </view>
          
          <!-- 子评论列表 (展开时显示) -->
          <view class="replies-list" wx:if="{{expandedMap[item.id]}}">
            <view class="reply-item" wx:for="{{item.replies}}" wx:for-item="replyItem" wx:for-index="replyIndex" wx:key="id" wx:if="{{replyItem.isNew || replyIndex < (repliesPagination[item.id] ? repliesPagination[item.id].currentPage * 6 : 6)}}">
              <view class="reply-header">
                <image class="reply-avatar" src="{{replyItem.author.avatar}}" bindtap="goToUserProfile" data-user-id="{{replyItem.authorId}}" />
                <view class="reply-user-info">
                  <text class="reply-username" bindtap="goToUserProfile" data-user-id="{{replyItem.authorId}}">{{replyItem.author.nickname}}</text>
                  <text class="reply-arrow">→</text>
                  <text class="reply-reply-to" bindtap="goToUserProfile" data-user-id="{{replyItem.replyTo ? replyItem.replyTo.id : ''}}">{{replyItem.replyTo ? replyItem.replyTo.nickname : '用户'}}</text>
                </view>
              </view>
              <text class="reply-content" bindtap="showReplyInput" data-comment="{{item}}" data-index="{{index}}" data-reply="{{replyItem}}">{{replyItem.content}}</text>
              <view class="reply-footer">
                <text class="reply-time">{{replyItem.createTime}}</text>
                <view class="reply-actions">
                  <view class="reply-action-btn {{replyItem.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikeReply" data-comment="{{item}}" data-index="{{index}}" data-reply="{{replyItem}}">
                    <image class="reply-icon" src="/static/icons/heart.png" />
                    <text class="reply-action-count">{{replyItem.likeCount}}</text>
                  </view>
                  <view class="reply-action-btn" bindtap="showReplyInput" data-comment="{{item}}" data-index="{{index}}" data-reply="{{replyItem}}">
                    <text class="reply-action-text">回复</text>
                  </view>
                </view>
              </view>
            </view>
            
            <!-- 按钮2和3：在子评论列表下方，展开时显示 -->
            <view class="replies-toggle-bottom" wx:if="{{expandedMap[item.id]}}">
              <!-- 按钮2：展开更多 ↓ (当还有更多子评论时显示) -->
              <view class="toggle-btn" wx:if="{{(repliesPagination[item.id] ? (repliesPagination[item.id].currentPage * 6) < item.replies.length : 6 < item.replies.length)}}" bindtap="loadMoreReplies" data-comment-id="{{item.id}}">
                <text class="toggle-text">展开更多 ↓</text>
              </view>
              
              <!-- 按钮3：收起 ↑ (始终显示) -->
              <view class="toggle-btn" bindtap="toggleReplies" data-comment-id="{{item.id}}">
                <text class="toggle-text">收起 ↑</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 分页加载更多 -->
      <view class="load-more-section" wx:if="{{pagination.hasMore}}">
        <view class="load-more-btn" bindtap="loadMoreComments">
          <text class="load-more-text">加载更多评论</text>
        </view>
      </view>
      
      <view class="no-more-section" wx:if="{{!pagination.hasMore && comments.length > 0}}">
        <text class="no-more-text">没有更多评论了</text>
      </view>
    </view>

    <!-- 回复输入框 -->
    <view class="reply-input-section" wx:if="{{replyInput.visible}}">
      <view class="reply-input-header">
        <text class="reply-title">回复</text>
        <view class="reply-cancel" bindtap="cancelReply">
          <text class="cancel-text">取消</text>
        </view>
      </view>
      <view class="input-container">
        <input class="reply-input" 
               placeholder="{{replyInput.placeholder}}" 
               bindinput="onCommentInput" 
               value="{{replyInput.content}}" />
        <button class="send-btn" bindtap="onSendComment">
          <text class="send-icon">➤</text>
        </button>
      </view>
    </view>

    <!-- 底部输入框 -->
    <view class="input-section">
      <view class="input-container">
        <input class="comment-input" 
               placeholder="写下你的看法..." 
               bindinput="onCommentInput" 
               value="{{replyInput.visible ? '' : replyInput.content}}" />
        <button class="send-btn" bindtap="onSendComment">
          <text class="send-icon">➤</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{currentTab}}" 
    bind:change="onTabChange"
  />

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onSharePost">
        <text class="sheet-icon">📤</text>
        <text class="sheet-text">分享帖子</text>
      </view>
      <view class="sheet-item" bindtap="onCollection">
        <text class="sheet-icon">📦</text>
        <text class="sheet-text">{{topic && topic.isFavorited ? '取消收藏' : '收藏话题'}}</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>