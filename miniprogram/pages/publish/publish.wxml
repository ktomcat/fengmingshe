<!-- 发布页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="发布话题" 
      background="#ffffff" 
      color="#000000" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 标题输入区 -->
    <view class="input-section">
      <input 
        class="title-input" 
        placeholder="请输入话题标题" 
        maxlength="50"
        value="{{title}}"
        bindinput="onTitleInput"
      />
      <text class="title-count">{{title.length}}/50</text>
    </view>

    <!-- 内容编辑区 -->
    <view class="content-section">
      <view class="content-toolbar">
        <view class="tool-btn {{activeTool === 'text' ? 'active' : ''}}" bindtap="switchToText">
          <text class="tool-icon">📝</text>
          <text class="tool-text">文本</text>
        </view>
        <view class="tool-btn {{activeTool === 'image' ? 'active' : ''}}" bindtap="switchToImage">
          <text class="tool-icon">🖼️</text>
          <text class="tool-text">图片</text>
        </view>
        <view class="tool-btn {{activeTool === 'vote' ? 'active' : ''}}" bindtap="switchToVote">
          <text class="tool-icon">📊</text>
          <text class="tool-text">投票</text>
        </view>
      </view>

      <!-- 内容编辑区域 -->
      <scroll-view class="content-editor" scroll-y="true">
        <!-- 动态生成的内容块 -->
        <view class="content-block" wx:for="{{contentBlocks}}" wx:key="index">
          
          <!-- 文本块 -->
          <view class="text-block" wx:if="{{item.type === 'text'}}">
            <textarea 
              class="text-input" 
              placeholder="请输入文本内容" 
              value="{{item.content}}"
              bindinput="onTextInput"
              data-index="{{index}}"
              maxlength="500"
            />
            <text class="text-count">{{item.content.length}}/500</text>
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>

          <!-- 图片块 -->
          <view class="image-block" wx:if="{{item.type === 'image'}}">
            <view class="image-uploader">
              <view class="image-preview" wx:if="{{item.content}}">
                <image class="preview-image" src="{{item.content}}" mode="aspectFill" />
                <text class="remove-image" bindtap="removeImage" data-index="{{index}}">✕</text>
              </view>
              <view class="upload-btn" wx:if="{{!item.content}}" bindtap="chooseImage" data-index="{{index}}">
                <text class="upload-icon">+</text>
                <text class="upload-text">添加图片</text>
              </view>
            </view>
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>

          <!-- 投票块 -->
          <view class="vote-block" wx:if="{{item.type === 'vote'}}">
            <text class="vote-title">投票选项</text>
            <view class="vote-options">
              <view class="vote-option" wx:for="{{item.options}}" wx:key="index" wx:for-item="option">
                <input 
                  class="option-input" 
                  placeholder="请输入选项内容" 
                  value="{{option.text}}"
                  bindinput="onOptionInput"
                  data-block-index="{{index}}"
                  data-option-index="{{optionIndex}}"
                />
                <text class="remove-option" bindtap="removeOption" data-block-index="{{index}}" data-option-index="{{optionIndex}}">✕</text>
              </view>
            </view>
            <view class="vote-actions">
              <text class="add-option" bindtap="addOption" data-index="{{index}}">+ 添加选项</text>
              <text class="vote-setting">
                <text class="setting-text">单选</text>
                <switch checked="{{item.isSingleChoice}}" bindchange="toggleVoteType" data-index="{{index}}" />
                <text class="setting-text">多选</text>
              </text>
            </view>
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>
        </view>

        <!-- 添加新内容块的按钮 -->
        <view class="add-block-section">
          <text class="add-block-hint">点击下方按钮添加内容</text>
          <view class="add-block-buttons">
            <text class="add-block-btn" bindtap="addTextBlock">📝 添加文本</text>
            <text class="add-block-btn" bindtap="addImageBlock">🖼️ 添加图片</text>
            <text class="add-block-btn" bindtap="addVoteBlock">📊 添加投票</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <view class="action-buttons">
        <button class="cancel-btn" bindtap="onCancel">取消</button>
        <button class="publish-btn {{canPublish ? 'active' : ''}}" bindtap="onPublish" disabled="{{!canPublish}}">
          发布
        </button>
      </view>
    </view>
  </view>
</view>