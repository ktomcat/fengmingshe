<!-- 发布页面 - 全新的HTML结构 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="发布话题" 
      background="#ffffff" 
      color="#000000" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 页面内容区域 -->
  <view class="page-content">
    
    <!-- 内容编辑区 -->
    <view class="content-section">
      <!-- 内容编辑区域 -->
      <scroll-view class="content-editor" scroll-y="true">
        <!-- 标题输入区 -->
        <view class="input-section">
          <input 
            class="title-input" 
            placeholder="请输入话题标题" 
            maxlength="50"
            value="{{title}}"
            bindinput="onTitleInput"
          />
          <text class="title-count">{{title.length}}/50</text>
        </view>
        
        <!-- 动态生成的内容块 -->
        <view class="content-block" wx:for="{{contentBlocks}}" wx:key="index">
          <!-- 文本块 -->
          <view class="text-block" wx:if="{{item.type === 'text'}}">
            <textarea 
              class="text-input" 
              placeholder="请输入文本内容..." 
              value="{{item.content}}"
              bindinput="onTextInput"
              data-index="{{index}}"
              maxlength="-1"
            />
            
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>

          <!-- 图片块 -->
          <view class="image-block" wx:if="{{item.type === 'image'}}">
            <view class="image-uploader">
              <view class="image-preview" wx:if="{{item.content}}">
                <image class="preview-image" src="{{item.content}}" mode="aspectFill" />
                <text class="remove-image" bindtap="removeImage" data-index="{{index}}">✕</text>
              </view>
              <view class="upload-btn" wx:if="{{!item.content}}" bindtap="chooseImage" data-index="{{index}}">
                <text class="upload-icon">+</text>
                <text class="upload-text">点击上传图片</text>
              </view>
            </view>
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>

          <!-- 投票块 -->
          <view class="vote-block" wx:if="{{item.type === 'vote'}}">
            <view class="vote-container">
              <view class="vote-header">
                <input 
                  class="vote-title-input" 
                  placeholder="请输入辩题  (例:AI会取代人类工作吗?)" 
                  value="{{item.title}}"
                  bindinput="onVoteTitleInput"
                  data-index="{{index}}"
                  maxlength="100"
                />
                <text class="vote-count">{{item.totalVotes || 0}} 人参与</text>
              </view>
              
              <view class="vote-content">
                <view class="vote-stats">
                  <view class="stats-left">
                    <text class="stats-label">支持 (正方)</text>
                    <text class="stats-value">{{item.positive && item.positive.count ? item.positive.count : 0}}票</text>
                  </view>
                  <view class="stats-right">
                    <text class="stats-label">反对 (反方)</text>
                    <text class="stats-value">{{item.negative && item.negative.count ? item.negative.count : 0}}票</text>
                  </view>
                </view>
                
                <view class="vote-progress-bar">
                  <view class="progress-track">
                    <view class="progress-fill positive" style="width: {{item.positivePercent || 0}}%;"></view>
                    <view class="progress-fill negative" style="width: {{item.negativePercent || 0}}%;"></view>
                    <view class="progress-divider" style="left: {{item.positivePercent || 0}}%;"></view>
                  </view>
                </view>
                
                <view class="vote-actions">
                  <button class="vote-btn positive" bindtap="onVotePositive" data-index="{{index}}">
                    <text class="btn-icon">👍</text>
                    <text class="btn-text">支持观点</text>
                  </button>
                  <button class="vote-btn negative" bindtap="onVoteNegative" data-index="{{index}}">
                    <text class="btn-icon">👎</text>
                    <text class="btn-text">反对观点</text>
                  </button>
                </view>
                
                <view class="vote-result">
                  <text class="result-text">读者将在这里选择支持正方或反方</text>
                </view>
              </view>
            </view>
            
            <view class="block-actions">
              <text class="action-btn" bindtap="moveBlockUp" data-index="{{index}}">⬆️</text>
              <text class="action-btn" bindtap="moveBlockDown" data-index="{{index}}">⬇️</text>
              <text class="action-btn delete" bindtap="deleteBlock" data-index="{{index}}">🗑️</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 全新的底部操作栏 -->
    <view class="bottom-actions">
      <!-- 添加内容区域 -->
      <view class="add-block-section">
        <text class="add-block-hint">添加内容板块</text>
        <view class="add-block-buttons">
          <text class="add-block-btn" bindtap="addTextBlock">
            <text class="btn-emoji">📝</text>
            <text>文本</text>
          </text>
          <text class="add-block-btn" bindtap="addImageBlock">
            <text class="btn-emoji">🖼️</text>
            <text>图片</text>
          </text>
          <text class="add-block-btn" bindtap="addVoteBlock">
            <text class="btn-emoji">📊</text>
            <text>辩题</text>
          </text>
        </view>
      </view>
      
      <!-- 操作按钮区域 -->
      <view class="action-buttons">
        <button class="cancel-btn" bindtap="onCancel">取消</button>
        <button class="publish-btn active" bindtap="onPublish">
          发布
        </button>
      </view>
    </view>
  </view>
</view>