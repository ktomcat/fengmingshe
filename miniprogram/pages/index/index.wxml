<!-- 首页页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="蜂鸣社" 
      background="#ffffff" 
      color="#f44343" 
      back="{{false}}"
      home-button="{{false}}"
      left-logo="{{true}}"
      show-title="{{false}}"
    ></navigation-bar>
  </view>


  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 头部搜索栏 -->
    <view class="header">
    <view class="search-container">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索话题、圈子或用户" bindinput="onSearchInput" value="{{searchText}}" />
        <view class="search-btn {{searchText ? 'show' : ''}}" bindtap="onSearch">
          <text class="search-btn-text">搜索</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 特色话题卡片 -->
  <view class="featured-card" wx:if="{{featuredTopic}}">
    <view class="card-image">
      <image class="bg-image" src="{{featuredTopic.images && featuredTopic.images[0] ? featuredTopic.images[0] : 'https://example.com/default.jpg'}}" mode="aspectFill" />
      <view class="image-overlay"></view>
    </view>
    <view class="card-content">
      <view class="topic-tag">
        <text class="tag-text">今日话题</text>
        <text class="participants">{{featuredTopic.likeCount}} 人点赞</text>
      </view>
      <text class="topic-title">{{featuredTopic.title}}</text>
      <view class="topic-actions">
        <text class="topic-desc">{{featuredTopic.content}}</text>
        <button class="join-btn" bindtap="goToTopic">加入讨论</button>
      </view>
    </view>
  </view>

  <!-- 热门讨论列表 -->
  <view class="discussions-section">
    <view class="section-header">
      <text class="section-title">热门讨论</text>
    </view>

    <!-- 动态生成讨论帖子 -->
    <view class="discussion-post" wx:for="{{discussions}}" wx:key="id" bindtap="goToTopicDetail" data-topic-id="{{item.id}}">
      <view class="post-header">
        <view class="user-info">
          <image class="avatar" src="{{item.author.avatar}}" />
          <view class="user-details">
            <text class="username">{{item.author.nickname}}</text>
            <text class="post-info">{{item.createTime}} · {{item.tags && item.tags[0] ? item.tags[0] : '生活'}}</text>
          </view>
        </view>
        <view class="more-btn" bindtap="showBottomSheet" data-topic="{{item}}">
          <text class="icon">⋯</text>
        </view>
      </view>
      
      <text class="post-title">{{item.title}}</text>
      <text class="post-content">{{item.content}}</text>
      
      <!-- 图片展示 -->
      <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
        <image class="post-image" wx:for="{{item.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
      </view>
      
      <!-- 标签展示 -->
      <view class="post-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="tag" wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      
      <view class="post-actions">
        <view class="action-buttons">
          <view class="action-btn style-unactive">
            <text class="icon">❤️</text>
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn">
            <text class="icon">💬</text>
            <text class="action-count">{{item.commentCount}}</text>
          </view>
          <view class="action-btn">
            <text class="icon">↗️</text>
            <text class="action-count">分享</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{currentTab}}" 
    bind:change="onTabChange"
  />
  </view>

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onSharePost">
        <text class="sheet-icon">📤</text>
        <text class="sheet-text">分享帖子</text>
      </view>
      <view class="sheet-item" bindtap="onCopyLink">
        <text class="sheet-icon">🔗</text>
        <text class="sheet-text">复制链接</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>