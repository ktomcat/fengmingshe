<!-- 首页页面 -->
<view class="page-container">
  <!-- 固定导航栏 -->
  <view class="fixed-navbar">
    <navigation-bar 
      title="蜂鸣社" 
      background="#ffffff" 
      color="#D7423D" 
      back="{{false}}"
      home-button="{{false}}"
      left-logo="{{true}}"
      show-title="{{false}}"
    ></navigation-bar>
  </view>


  <!-- 页面内容区域 -->
  <view class="page-content">
    <!-- 头部搜索栏 -->
    <view class="header">
    <view class="search-container">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索话题、精选或用户" bindinput="onSearchInput" value="{{searchText}}" />
        <view class="search-btn {{searchText ? 'show' : ''}}" bindtap="onSearch">
          <text class="search-btn-text">搜索</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 特色话题卡片 -->
  <view class="featured-card" wx:if="{{featuredTopic}}">
    <view class="card-image">
      <image class="bg-image" src="{{featuredTopic.image ? featuredTopic.image : 'https://example.com/default.jpg'}}" mode="aspectFill" />
      <view class="image-overlay"></view>
    </view>
    <view class="card-content">
      <view class="topic-tag">
        <text class="tag-text">今日话题</text>
        <text class="participants">{{featuredTopic.likeCount}} 人点赞</text>
      </view>
      <text class="topic-title">{{featuredTopic.title}}</text>
      <view class="topic-actions">
        <text class="topic-desc">{{featuredTopic.displayContent}}</text>
        <button class="join-btn" bindtap="goToTopic">加入讨论</button>
      </view>
    </view>
  </view>

  <!-- 热门讨论列表 -->
  <view class="discussions-section">
    <view class="section-header">
      <text class="section-title">热门讨论</text>
    </view>

    <!-- 动态生成讨论帖子 -->
    <view class="discussion-post" wx:for="{{discussions}}" wx:key="id">
      <view class="post-content-area" bindtap="goToTopicDetail" data-topic-id="{{item.id}}">
        <view class="post-header">
          <view class="user-info" bindtap="goToUserProfile" data-user-id="{{item.authorId}}">
            <image class="avatar" src="{{item.author.avatar}}" />
            <view class="user-details">
              <text class="username">{{item.author.nickname}}</text>
              <text class="post-info">{{item.createTime}}</text>
            </view>
          </view>
          <view class="more-btn" catchtap="showBottomSheet" data-topic="{{item}}">
            <text class="icon">⋯</text>
          </view>
        </view>
        
        <text class="post-title">{{item.title}}</text>
        
        <!-- 显示第一个文本内容 -->
        <text class="post-content" wx:if="{{item.displayContent}}">{{item.displayContent}}</text>
        
        <!-- 图片展示 - 横向滚动布局 -->
        <view class="post-images-container" wx:if="{{item.imageCount > 0}}">
          <scroll-view class="post-images-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
            <view class="post-images-list">
              <image class="post-image" wx:for="{{item.content}}" wx:for-item="contentItem" wx:key="index" wx:if="{{contentItem.type === 'image'}}" src="{{contentItem.content}}" mode="aspectFill" />
            </view>
          </scroll-view>
          <view class="scroll-indicator" wx:if="{{item.imageCount > 3}}">
            <text class="indicator-text">滑动查看更多</text>
          </view>
        </view>
      </view>
      
      <!-- 辩题特别标注 -->
      <view class="vote-badge" wx:if="{{item.hasVote}}">
        <view class="vote-badge-content {{item.voteInfo.participationLevel}}">
          <text class="vote-icon">VS:</text>
          <text class="vote-text">{{item.voteInfo.title}}</text>
          <text class="vote-count">{{item.voteInfo.totalVotes}}人参与</text>
        </view>
      </view>

      <!-- 操作按钮区域（独立事件处理，阻止冒泡） -->
      <view class="post-actions">
        <view class="action-buttons">
          <view class="action-btn {{item.userLiked ? 'style-active' : 'style-unactive'}}" bindtap="onLikePost" data-topic-id="{{item.id}}" data-index="{{index}}">
            <image class="icon" src="/static/icons/heart.png" />
            <text class="action-count">{{item.likeCount}}</text>
          </view>
          <view class="action-btn style-unactive" bindtap="onCommentPost" data-topic-id="{{item.id}}">
            <image class="icon" src="/static/icons/msg.png" />
            <text class="action-count">{{item.commentCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <bottom-nav 
    wx:if="{{true}}"
    current="{{0}}" 
    bind:change="onTabChange"
  />
  </view>

  <!-- 底部菜单栏遮罩 -->
  <view class="bottom-sheet-overlay {{showBottomSheet ? 'active' : ''}}" bindtap="closeBottomSheet">
    <view class="bottom-sheet {{showBottomSheet ? 'active' : ''}}" catchtap="">
      <view class="sheet-item" bindtap="onCollection">
        <text class="sheet-icon">📦</text>
        <text class="sheet-text">{{selectedTopic && selectedTopic.isFavorited ? '取消收藏' : '收藏话题'}}</text>
      </view>
      <view class="sheet-item" bindtap="onReportContent">
        <text class="sheet-icon">🚩</text>
        <text class="sheet-text">举报内容</text>
      </view>
      <view class="sheet-item" bindtap="onBlockUser">
        <text class="sheet-icon">🚫</text>
        <text class="sheet-text">拉黑用户</text>
      </view>
      <view class="sheet-cancel" bindtap="closeBottomSheet">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>
</view>