<!-- 用户主页页面 -->
<view class="user-container">
  <!-- 顶部导航栏 - 与话题页统一 -->
  <view class="fixed-navbar" id="fixed-navbar">
    <navigation-bar 
      title="个人主页" 
      background="#ffffff" 
      color="#000000" 
      back="{{true}}"
      home-button="{{false}}"
      left-logo="{{false}}"
      show-title="{{true}}"
    ></navigation-bar>
  </view>

  <!-- 页面内容 -->
  <view class="page-content">
    <!-- 用户信息区域 -->
    <view class="user-section">
      <view class="user-info">
        <view class="avatar-container">
          <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
        </view>
        <view class="user-details">
          <view class="name-container">
            <text class="user-name">{{userInfo.name}}</text>
          </view>
          <view class="signature-container">
            <text class="user-signature">{{userInfo.signature}}</text>
          </view>
          <!-- 关注/取消关注按钮 -->
          <view class="follow-action" wx:if="{{!isCurrentUser}}">
            <view class="follow-btn {{isFollowing ? 'followed' : ''}}" bindtap="onFollowToggle">
              <text>{{isFollowing ? '已关注' : '关注'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-section">
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-value">{{stats.views}}</text>
          <text class="stat-label">浏览</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.likes}}</text>
          <text class="stat-label">获赞</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.followers}}</text>
          <text class="stat-label">粉丝</text>
        </view>
      </view>
    </view>

    <!-- 标签页导航 - 只显示Ta的作品 -->
    <view class="tab-navigation">
      <view class="tab-header">
        <view class="tab-item {{activeTab === 'posts' ? 'active' : ''}}" bindtap="switchTab" data-tab="posts">
          <text class="tab-text">Ta的作品</text>
          <view class="tab-indicator" wx:if="{{activeTab === 'posts'}}"></view>
        </view>
      </view>

      <!-- 内容区域 -->
      <view class="tab-content">
        <!-- Ta的作品 -->
        <view class="feed-list" wx:if="{{activeTab === 'posts'}}">
          <view class="feed-card" wx:for="{{posts}}" wx:key="id" wx:for-item="item" bindtap="onPostTap" data-post="{{item}}">
            <text class="feed-title">{{item.title}}</text>
            <view class="feed-meta">
              <text class="feed-date">{{item.date}}</text>
              <view class="feed-stats">
                <view class="stat-item">
                  <text class="stat-count">浏览 {{item.views}}</text>
                </view>
                <view class="stat-item">
                  <text class="stat-count">获赞 {{item.likes}}</text>
                </view>
              </view>
            </view>
          </view>
          
          <!-- 加载更多 -->
          <view class="load-more" wx:if="{{posts.length > 0}}">
            <text>没有更多了</text>
          </view>
        </view>
        
        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{activeTab === 'posts' && posts.length === 0}}">
          <text>暂无发布内容</text>
        </view>
      </view>
    </view>
  </view>
</view>